# Copy this file to .env and adjust:  cp .env.example .env

# --- Required ---
# Setting this to TRUE means you accept the Minecraft EULA:
# https://minecraft.net/terms
EULA=TRUE

# --- Server version ---
# LATEST = download the newest Bedrock server on every container start.
# Pin to a specific version (e.g. 1.21.84.1) if you need to hold back.
VERSION=LATEST

# --- World / gameplay ---
# Shown in the LAN server list
SERVER_NAME=My Bedrock Server
# Note: worlds (create/switch/import) are managed by scripts/world.sh or
# the dashboard, not here.
GAMEMODE=survival
DIFFICULTY=normal
MAX_PLAYERS=10
ALLOW_CHEATS=false
VIEW_DISTANCE=32

# --- Access control ---
# ONLINE_MODE=true requires players to be signed in to Xbox Live
ONLINE_MODE=true
# Set ALLOW_LIST=true and list players as "gamertag:xuid,gamertag:xuid"
ALLOW_LIST=false
ALLOW_LIST_USERS=

# --- Network ---
SERVER_PORT=19132
SERVER_PORT_V6=19133

# --- Dashboard ---
# Web dashboard port: http://<server-ip>:8080 (keep it LAN-only)
DASH_PORT=8080
# Dashboard login (HTTP Basic). Leave DASH_PASSWORD empty and bootstrap.sh
# generates a random one for you (printed once, stored here).
DASH_USERNAME=admin
DASH_PASSWORD=

# --- World map ---
# When to re-render the world map from the newest backup (cron, in TZ)
MAP_CRON=30 4 * * *

# --- Automatic updates ---
# How often to check Mojang for a new release (cron syntax, in TZ below)
UPDATE_CRON=15 * * * *
# In-game warning time before the update restart; 0 = restart immediately
UPDATE_WARN_MINUTES=5

# --- Backups ---
# Console password the backup service uses to talk to the server over the
# internal network (never exposed to the LAN). Pick anything non-trivial.
RCON_PASSWORD=change-me
# Timezone for backup schedules, e.g. Asia/Kuala_Lumpur
TZ=UTC
# Backup timing and retention live in backup/config.yml

# --- Off-site backups (optional) ---
# Uncomment to enable the restic off-site service:
#COMPOSE_PROFILES=offsite
# Where to push backups. Examples:
#   sftp:backup@192.168.2.50:/srv/blockdeck-restic   (Linux box / NAS over SSH)
#   /mnt/usb/blockdeck-restic                        (local/mounted path)
RESTIC_REPOSITORY=
# Encrypts the off-site repository — losing this means losing the backups!
RESTIC_PASSWORD=
# When to push (cron syntax, in TZ above) and what to keep
OFFSITE_CRON=30 3 * * *
KEEP_DAILY=7
KEEP_WEEKLY=4
KEEP_MONTHLY=6
