# Copy this file to .env and adjust:  cp .env.example .env

# --- Required ---
# Setting this to TRUE means you accept the Minecraft EULA:
# https://minecraft.net/terms
EULA=TRUE

# --- Server version ---
# LATEST = download the newest Bedrock server on every container start.
# Pin to a specific version (e.g. 1.21.84.1) if you need to hold back.
VERSION=LATEST

# --- World / gameplay ---
# Shown in the LAN server list
SERVER_NAME=My Bedrock Server
# Folder name under data/worlds/ — also the target for world imports.
# Avoid spaces; pick once and keep it.
LEVEL_NAME=world
GAMEMODE=survival
DIFFICULTY=normal
MAX_PLAYERS=10
ALLOW_CHEATS=false
VIEW_DISTANCE=32

# --- Access control ---
# ONLINE_MODE=true requires players to be signed in to Xbox Live
ONLINE_MODE=true
# Set ALLOW_LIST=true and list players as "gamertag:xuid,gamertag:xuid"
ALLOW_LIST=false
ALLOW_LIST_USERS=

# --- Network ---
SERVER_PORT=19132
SERVER_PORT_V6=19133
